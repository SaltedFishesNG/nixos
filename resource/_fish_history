- cmd: nh os switch ~/Projects/nixos
- cmd: nixos-rebuild switch --sudo --flake ~/Projects/nixos --log-format internal-json -v &| nom --json
- cmd: nix build --log-format bar-with-logs
- cmd: nix store gc
- cmd: nix flake update
- cmd: nix why-depends /run/current-system nixpkgs#python3
- cmd: nix run github:nix-community/nix-index-database libgtk-3.so
- cmd: find /nix/store -name "libgtk-3.so" 2>/dev/null

- cmd: nix run nixpkgs#python3 -- -m http.server
- cmd: nix run nixpkgs#xorg.xwininfo
- cmd: nix run nixpkgs#fastfetch

- cmd: vi ~/.local/share/fish/fish_history
- cmd: systemctl restart sing-box
- cmd: systemctl stop sing-box
- cmd: nohup mpv --volume=70 --shuffle Music/*
- cmd: qrencode -t UTF8
- cmd: tar -tvf foo.tar | awk '{sum += $3} END {print sum/1024/1024 " MB"}'
